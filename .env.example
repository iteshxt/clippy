# BACKEND ENVIRONMENT VARIABLES (.env.example)
# Copy this file to .env and fill in your actual values

# MongoDB Connection URI
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/dbname
# For Local MongoDB: mongodb://username:password@localhost:27017/dbname
MONGO_URI=mongodb+srv://iteshxt:Itesh@2003@clippy.ucnsu9g.mongodb.net/clippy?appName=clippy

# Server Configuration
BACKEND_PORT=3001
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# File Upload Configuration
MAX_FILE_SIZE_MB=10

# Rate Limiting (browser fingerprint-based)
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=50

# Paste Expiry Configuration (in minutes)
PASTE_DEFAULT_EXPIRY_MINUTES=60
PASTE_MAX_EXPIRY_MINUTES=1440
